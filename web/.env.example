# Copy to .env.local and fill in your values

# OpenRouter API key (get one at https://openrouter.ai/keys)
# If omitted, the app runs in mock mode with sample data
OPENROUTER_API_KEY=sk-or-...

# Model to use via OpenRouter (default: anthropic/claude-3.5-sonnet)
# Other good options:
#   openai/gpt-4o
#   openai/gpt-4o-mini        (cheaper)
#   google/gemini-pro-1.5
#   meta-llama/llama-3.1-70b-instruct  (free tier)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Your deployed site URL (used in OpenRouter request headers)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
